            Rectangle()
                .fill(dividerColor)
                .frame(height: 1)
                .padding(.horizontal, 14)

            HStack(spacing: 0) {
                ForEach(Array(labels.enumerated()), id: \.offset) { idx, label in
                    Button(action: {
                        onTap(idx)
                    }) {
                        Text(label)
                            .font(.system(size: 15, weight: .medium, design: .rounded))
                            .foregroundStyle(actionColor)
                            .frame(maxWidth: .infinity)
