                                showsDivider: false,
                                matchPickerFont: true
                            ) {
                                Image(systemName: "chevron.right")
                                    .font(.system(size: 18, weight: .medium))
                                    .foregroundStyle(isDarkMode ? Color.white.opacity(0.42) : Color.black.opacity(0.30))
                                    .padding(.trailing, chevronTrailingInset)
