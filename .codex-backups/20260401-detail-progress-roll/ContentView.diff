+        let blur = max(0.0, (1.0 - depthScale) * 3.0)
+
+        return SelectedGalaxyCardState(
+            offset: CGSize(width: screenX * galaxyScale, height: screenY * galaxyScale),
+            scale: CGFloat(scale),
+            tiltY: cardTiltY,
+            tiltZ: 15,
+            opacity: opacity,
+            blur: CGFloat(blur)
+        )
+    }
+}
