+        let rollShare = rollDuration / (rollDuration + popDuration)
+        if progress <= rollShare {
+            let rollProgress = min(1.0, max(0.0, progress / max(rollShare, 0.0001)))
+            return rollRenderState(for: request, targetCardWidth: targetCardWidth, progress: rollProgress)
+        }
+
+        let popProgress = min(1.0, max(0.0, (progress - rollShare) / max(1 - rollShare, 0.0001)))
+        let frontState = rollRenderState(for: request, targetCardWidth: targetCardWidth, progress: 1)
+        let xT = galaxySmoothStep(min(1.0, max(0.0, popProgress / 0.86)))
+        let yT = galaxySmoothStep(min(1.0, max(0.0, (popProgress - 0.02) / 0.66)))
+        let scaleT = galaxySmoothStep(min(1.0, max(0.0, (popProgress - 0.08) / 0.84)))
+        let blurT = min(1.0, popProgress * 2.8)
+
+        return SelectedGalaxyCardState(
+            offset: CGSize(
+                width: galaxyLerp(frontState.offset.width, 0, xT),
+                height: galaxyLerp(frontState.offset.height, 0, yT)
+            ),
+            scale: galaxyLerp(frontState.scale, 1, scaleT),
+            tiltY: 0,
+            tiltZ: 0,
+            opacity: galaxyLerp(frontState.opacity, 1, scaleT),
+            blur: galaxyLerp(frontState.blur, 0, blurT)
+        )
+    }
