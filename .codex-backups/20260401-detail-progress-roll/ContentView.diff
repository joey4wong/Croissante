+    private var cardSurfaceColor: Color {
+        AppColors.elevatedSurfaceFill(themeMode: appState.themeMode, isDarkMode: isDarkMode)
+    }
+
+    private var cardBorderColor: Color {
+        AppColors.elevatedSurfaceBorder(themeMode: appState.themeMode, isDarkMode: isDarkMode)
+    }
+
+    private var accentBorder: LinearGradient {
+        LinearGradient(
+            colors: [
+                Color(red: 0.28, green: 0.95, blue: 0.56).opacity(isDarkMode ? 0.82 : 0.62),
+                Color(red: 0.16, green: 0.78, blue: 0.46).opacity(isDarkMode ? 0.72 : 0.52)
+            ],
+            startPoint: .topLeading,
+            endPoint: .bottomTrailing
+        )
+    }
+
+    private var backLayerCount: Int {
+        max(visibleLayers - 1, 0)
+    }
+
+    private func layerOffset(_ layer: Int) -> CGSize {
+        guard backLayerCount > 0 else { return .zero }
+        let progress = Double(layer + 1) / Double(backLayerCount)
+        let compressed = pow(progress, 0.78)
+        let spread = 12.5 * compressed
+        return CGSize(width: -spread, height: spread)
+    }
+
+    private func layerOpacity(_ layer: Int) -> Double {
+        guard backLayerCount > 0 else { return 1 }
+        let progress = Double(layer + 1) / Double(backLayerCount)
+        return 0.32 + (1.0 - progress) * 0.56
+    }
+
+    private func accentOpacity(_ layer: Int) -> Double {
+        guard backLayerCount > 0 else { return 0.82 }
+        let progress = Double(layer + 1) / Double(backLayerCount)
+        return 0.18 + (1.0 - progress) * 0.54
+    }
+
+    var body: some View {
+        ZStack {
+            ForEach((0..<backLayerCount).reversed(), id: \.self) { layer in
+                RoundedRectangle(cornerRadius: 6, style: .continuous)
+                    .fill(cardSurfaceColor)
+                    .overlay(
+                        RoundedRectangle(cornerRadius: 6, style: .continuous)
+                            .stroke(cardBorderColor, lineWidth: 0.8)
+                    )
+                    .overlay(
+                        RoundedRectangle(cornerRadius: 6, style: .continuous)
+                            .stroke(accentBorder.opacity(accentOpacity(layer)), lineWidth: 1.0)
+                    )
+                    .frame(width: 66, height: 66)
+                    .offset(layerOffset(layer))
+                    .opacity(layerOpacity(layer))
+            }
+            GalaxyWordCard(word: word)
+        }
+    }
 }
 
