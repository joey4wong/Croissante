+        let rxRad = ringTiltX * .pi / 180.0
+        let rzRad = ringTiltZ * .pi / 180.0
+        let cosRx = cos(rxRad), sinRx = sin(rxRad)
+        let cosRz = cos(rzRad), sinRz = sin(rzRad)
+        let m00 = cosRz
+        let m02 = sinRz * sinRx
+        let m10 = sinRz
+        let m12 = -cosRz * sinRx
+        let m22 = cosRx
+
+        let wx = m00 * lx + m02 * lz
+        let wy = m10 * lx + m12 * lz
